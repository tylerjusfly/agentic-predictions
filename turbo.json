{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**"],
      "inputs": ["src/**/*.tsx", "src/**/*.ts", "*.ts", "*.tsx", "package.json"]
    },
    "dev": {
      "dependsOn": ["build"],
      "cache": false,
      "persistent": true
    },
    "start": {
      "cache": false,
      "persistent": true
    }
  },
  "globalEnv": [
    "API_PORT",
    "API_ENDPOINT",
    "WEB_PORT",
    "NODE_ENV",
    "AUTH_TOKEN",
    "LLM_PROVIDER",
    "GEMINI_API_KEY",
    "OPENAI_API_KEY",
    "GEMINI_MODEL",
    "NEXT_PUBLIC_DISABLE_WELCOME_SCREEN",
    "SMTP_USER",
    "SMTP_SECURE",
    "SMTP_PASS",
    "BETTER_AUTH_SECRET",
    "WEB_URL",
    "CHROMA_URL",
    "GOOGLE_CLIENT_ID",
    "GOOGLE_CLIENT_SECRET"
  ]
}